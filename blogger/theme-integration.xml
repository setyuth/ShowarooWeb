<!--
  ShowAroo — Blogger theme integration snippet (Phase 0).
  1. Theme -> Edit HTML.
  2. Paste the preconnect/style links inside <head>.
  3. Paste the env config + module bootstrap just before </body>.
  4. Replace setyuth, the version tag, and the TMDB credential.
  Source modules are served from a version-pinned CDN; Blogger hosts only this thin layer.
  A browser-side TMDB key is inherently public: use a read-only key.
-->

<!-- SEO baseline (inside <head>, before the module) -->
<meta name="description" content="ShowAroo — discover movies and TV shows."/>
<meta property="og:site_name" content="ShowAroo"/>
<meta property="og:type" content="website"/>
<meta name="twitter:card" content="summary_large_image"/>
<link rel="canonical" href="https://showaroo.blogspot.com/"/>

<!-- ===== inside <head> ===== -->
<link rel="preconnect" href="https://image.tmdb.org" crossorigin="anonymous"/>
<link rel="preconnect" href="https://api.themoviedb.org" crossorigin="anonymous"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/setyuth/ShowarooWeb@v0.0.0/src/styles/reset.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/setyuth/ShowarooWeb@v0.0.0/src/styles/tokens.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/setyuth/ShowarooWeb@v0.0.0/src/components/Image/lazyimg.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/setyuth/ShowarooWeb@v0.0.0/src/styles/motion.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/setyuth/ShowarooWeb@v0.0.0/src/styles/base.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/setyuth/ShowarooWeb@v0.0.0/src/styles/layout.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/setyuth/ShowarooWeb@v0.0.0/src/components/components.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/setyuth/ShowarooWeb@v0.0.0/src/styles/pages/home.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/setyuth/ShowarooWeb@v0.0.0/src/styles/pages/search.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/setyuth/ShowarooWeb@v0.0.0/src/styles/pages/detail.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/setyuth/ShowarooWeb@v0.0.0/src/styles/pages/watch.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/setyuth/ShowarooWeb@v0.0.0/src/styles/pages/library.css"/>

<!-- ===== app mount point in <body> ===== -->
<div id="showaroo-app"></div>

